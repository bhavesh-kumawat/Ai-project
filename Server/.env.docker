# Environment
NODE_ENV=development
PORT=5000
HOST=0.0.0.0

# Database
MONGO_URI=mongodb://localhost:27017/ai-media-gen

# JWT Authentication
JWT_ACCESS_SECRET=your_jwt_access_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Razorpay Payment Gateway
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=ai-generations
CLOUDINARY_SIGN_URLS=false
CLOUDINARY_AUTO_CLEANUP=false
CLOUDINARY_EXPIRY_DAYS=30

# AI Providers
OPENAI_API_KEY=your_openai_api_key
OPENAI_IMAGE_MODEL=dall-e-3
OPENAI_ENABLED=true

STABILITY_API_KEY=your_stability_api_key
STABILITY_ENABLED=true
STABILITY_BASE_URL=https://api.stability.ai
STABILITY_VIDEO_POLL_INTERVAL_MS=5000
STABILITY_VIDEO_MAX_POLL_ATTEMPTS=60

GEMINI_API_KEY=your_gemini_api_key
GEMINI_ENABLED=true
GEMINI_IMAGE_MODEL=gemini-2.0-flash-exp-image-generation

# Default providers used by generation jobs
AI_IMAGE_PROVIDER=openai
AI_VIDEO_PROVIDER=stability

# Security (Optional but recommended)
# FRONTEND_URL=http://localhost:5173
# TRUST_PROXY=false
# COOKIE_SECRET=your_cookie_secret
# Static Files (Optional)
# SERVE_STATIC=true
# STATIC_DIR=Public

# Stripe Payment Gateway
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here
CLIENT_URL=http://localhost:5173

# SMTP (Email) Settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="Skull Bot <your-email@gmail.com>"
